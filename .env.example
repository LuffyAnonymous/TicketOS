# TicketOS Environment Configuration Template

# LiveTicketGroup credentials
LIVE_USERNAME=
LIVE_PASSWORD=

# Ticketshop credentials (inventory checking)
TICKETSHOP_USERNAME=
TICKETSHOP_PASSWORD=

# FootballTicketNet credentials
FOOTBALLTICKETNET_USERNAME=
FOOTBALLTICKETNET_PASSWORD=

# Fanpass credentials
FANPASS_USERNAME=
FANPASS_PASSWORD=

# Tixstock credentials
TIXSTOCK_USERNAME=
TIXSTOCK_PASSWORD=

# Telegram Alerts Configuration
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Database connection URL
# Use postgresql://username:password@localhost:5432/dbname for PostgreSQL
# Defaults to local SQLite if left empty or connection fails
DATABASE_URL=sqlite:///order_ticket_db.sqlite

# Security keys (REQUIRED - cannot be left empty or set to default insecure values)
ADMIN_PASSWORD= # Choose a secure password for the admin dashboard user
JWT_SECRET=     # Run a command like 'openssl rand -hex 32' to generate a secure secret key
