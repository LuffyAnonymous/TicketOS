# TicketOS Production Environment Configuration Template

# Operational Data Directory (defaults to local data/ folder if unset)
DATA_DIR=/app/data

# Database connection URL
# PostgreSQL: postgresql://username:password@localhost:5432/dbname
# Defaults to SQLite in DATA_DIR if left empty
DATABASE_URL=

# Application Security Keys
ADMIN_PASSWORD=             # Choose a secure admin dashboard password
JWT_SECRET=                 # Execute 'openssl rand -hex 32' to generate a secure secret key

# Network Configuration
TRUST_PROXY=false           # Set to true if running behind Nginx reverse proxy
FLASK_ENV=production        # Set to production for live deployment

# Background Process Execution
AUTO_START_SCHEDULER=false  # Set to true to run interval checks automatically on startup

# Telegram Alerts Configuration
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Scraper Platform Credentials
LTG_USERNAME=
LTG_PASSWORD=

FTN_USERNAME=
FTN_PASSWORD=

TICKETSHOP_USERNAME=
TICKETSHOP_PASSWORD=

# Playwright Linux Container Workarounds (Set to true in Docker if needed)
PLAYWRIGHT_NO_SANDBOX=false
PLAYWRIGHT_DISABLE_DEV_SHM=false
